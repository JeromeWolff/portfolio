---
import { Briefcase } from '@lucide/astro';

import Section from './Section.astro';

import { experienceConfig } from '@config/experience';

const currentRegex = /heute|present|current/i;
---

<Section
  id="experience"
  titleId="experience-heading"
  title="Experience"
  class="experience-section"
  titleClass="experience-title"
  contentClass="experience-content"
>
  <Briefcase slot="icon" size={28} aria-hidden />
  <ol class="experience-timeline">
    {
      experienceConfig.experiences.map((experience) => {
        const { company, duration, role } = experience;
        const description = 'description' in experience ? experience.description : undefined;
        const isCurrent = currentRegex.test(duration);

        return (
          <li class="experience-item">
            <div class="experience-marker" aria-hidden />
            <div class="experience-body">
              <div class="experience-meta">
                <span class="experience-role">{role}</span>
                <span class="experience-company">{company}</span>
                <span
                  class:list={['experience-duration', isCurrent && 'experience-duration-current']}
                >
                  {duration}
                </span>
              </div>
              {description ? <p class="experience-description">{description}</p> : null}
            </div>
          </li>
        );
      })
    }
  </ol>
</Section>
