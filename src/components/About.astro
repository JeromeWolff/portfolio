---
import SectionHead from '@components/SectionHead.astro';
import { aboutConfig } from '@config/about';

const { birthdate, building, facts, offClock, paragraphs } = aboutConfig;

function calculateAge(dob: string): number {
  const d = new Date(dob);
  const now = new Date();
  let age = now.getFullYear() - d.getFullYear();
  const m = now.getMonth() - d.getMonth();
  if (m < 0 || (m === 0 && now.getDate() < d.getDate())) age -= 1;
  return age;
}
const age = calculateAge(birthdate);

const [lead, ...body] = paragraphs;
---

<section id="about" class="pt-20 md:pt-28" aria-labelledby="about-heading">
  <SectionHead
    mark="About"
    note={`b. 2004 · age ${age}`}
    title="Who's behind the systems"
    titleId="about-heading"
  />

  <div class="mx-auto mt-12 max-w-6xl px-5 sm:px-8 md:mt-16">
    <div class="grid grid-cols-12 gap-x-8 gap-y-12">
      <!-- Narrative -->
      <div class="col-span-12 md:col-span-6 md:col-start-3" data-reveal>
        <p class="text-xl leading-relaxed text-ink">{lead}</p>
        {body.map((para) => <p class="mt-5 leading-relaxed text-graphite">{para}</p>)}
      </div>

      <!-- Field notes -->
      <aside
        class="col-span-12 md:col-span-3 md:col-start-10"
        data-reveal
        style="--reveal-delay: 100ms"
        aria-label="Field notes"
      >
        <dl class="m-0">
          <div class="flex items-baseline justify-between border-t border-ink py-2">
            <dt class="mono-label m-0">Age</dt>
            <dd class="mono-data m-0 text-sm font-medium text-ink">{age}</dd>
          </div>
          {
            facts.map((f) => (
              <div class="flex items-baseline justify-between gap-3 border-t border-rule py-2">
                <dt class="mono-label m-0 shrink-0">{f.key}</dt>
                <dd class="mono-data m-0 text-right text-sm text-ink">{f.value}</dd>
              </div>
            ))
          }
        </dl>

        <p class="mono-label mt-8 mb-3">Builds</p>
        <ul class="flex flex-col gap-2.5 list-none m-0 p-0">
          {
            building.map((item) => (
              <li class="grid grid-cols-[0.9rem_1fr] gap-2 text-sm leading-snug text-graphite">
                <span class="mt-1.5 h-1 w-1 bg-accent" aria-hidden="true" />
                {item}
              </li>
            ))
          }
        </ul>

        <p class="mt-8 border-t border-rule pt-4 text-sm italic leading-relaxed text-graphite">
          {offClock}
        </p>
      </aside>
    </div>
  </div>
</section>
