---
interface Props {
  id?: string;
  titleId?: string;
  title: string;
  class?: string;
  titleClass?: string;
  contentClass?: string;
}

const {
  id,
  titleId,
  title,
  class: className = '',
  titleClass = '',
  contentClass = '',
} = Astro.props;
const hasIcon = Astro.slots.has('icon');
---

<section id={id} class:list={['app-section', className]} aria-labelledby={titleId}>
  <div class="section-content">
    <h2 id={titleId} class:list={['section-title', titleClass]}>
      {
        hasIcon ? (
          <span class="section-title-icon" aria-hidden="true">
            <slot name="icon" />
          </span>
        ) : null
      }
      {title}
    </h2>
    <div class:list={['section-children', contentClass]}>
      <slot />
    </div>
  </div>
</section>
