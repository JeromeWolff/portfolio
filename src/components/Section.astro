---
interface Props {
  id?: string;
  titleId?: string;
  title: string;
  class?: string;
  titleClass?: string;
  contentClass?: string;
}

const { id, titleId, title, class: className = '', contentClass = '' } = Astro.props;

const hasIcon = Astro.slots.has('icon');
---

<section id={id} class:list={['w-full py-16', className]} aria-labelledby={titleId}>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <h2
      id={titleId}
      class:list={[
        'mb-8 flex items-center justify-center gap-2.5 text-center text-3xl font-bold tracking-tight sm:text-4xl',
      ]}
    >
      {
        hasIcon && (
          <span class="text-primary-light" aria-hidden="true">
            <slot name="icon" />
          </span>
        )
      }
      {title}
    </h2>
    <div class:list={['flex flex-col gap-4', contentClass]}>
      <slot />
    </div>
  </div>
</section>
