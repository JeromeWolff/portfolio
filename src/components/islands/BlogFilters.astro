---
import { BookOpen, CalendarDays, Funnel, Search } from '@lucide/astro';

import { getBlogList } from '@blog/utils/listing';

import type {
  BlogListFilters,
  BlogPostRecord,
  BlogSortOrder,
  BlogTaxonomyOption,
} from '@blog/types';

interface Props {
  posts: BlogPostRecord[];
  availableTags: BlogTaxonomyOption[];
  availableCategories: BlogTaxonomyOption[];
  initialFilters?: BlogListFilters;
  introText: string;
}

const { posts, availableTags, availableCategories, initialFilters = {}, introText } = Astro.props;

const resolvedInitialFilters: BlogListFilters = {
  page: 1,
  pageSize: 10,
  sort: 'newest' satisfies BlogSortOrder,
  ...initialFilters,
};

const initialListing = getBlogList(
  posts,
  availableTags,
  availableCategories,
  resolvedInitialFilters
);

const idPrefix = `blog-filters-${
  Astro.url.pathname.replaceAll('/', '-').replace(/[^a-z0-9-]/gi, '') || 'index'
}`;

const stateJson = JSON.stringify({
  posts,
  availableTags,
  availableCategories,
  initialFilters: resolvedInitialFilters,
}).replace(/</g, '\\u003c');
---

<section
  id="blog"
  class="w-full py-20 md:py-28"
  aria-labelledby={`${idPrefix}-heading`}
  data-blog-filters
>
  <script type="application/json" data-blog-state is:inline set:html={stateJson} />

  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <!-- Section header -->
    <div class="mb-10 text-center">
      <div
        class="mb-4 inline-flex items-center gap-1.5 rounded-full border border-divider-2 px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-primary-light"
        style="background: rgba(59, 130, 246, 0.08);"
      >
        <BookOpen size={11} aria-hidden="true" />
        Blog
      </div>
      <h1 id={`${idPrefix}-heading`} class="mb-4 text-4xl font-bold tracking-tight sm:text-5xl">
        Blog
      </h1>
      <p class="mx-auto max-w-2xl text-lg leading-relaxed text-secondary">{introText}</p>
    </div>

    <!-- Toolbar -->
    <div class="mb-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
      <!-- Search -->
      <label
        class="flex min-w-48 flex-1 items-center gap-2.5 rounded-xl border border-divider px-4 py-2.5 transition-colors focus-within:border-primary/40"
        style="background: var(--color-card);"
        for={`${idPrefix}-search`}
      >
        <Search size={15} class="shrink-0 text-subtle" aria-hidden="true" />
        <input
          id={`${idPrefix}-search`}
          type="search"
          value={initialListing.appliedFilters.search}
          placeholder="Search posts…"
          aria-label="Search blog posts"
          class="flex-1 bg-transparent text-sm text-foreground placeholder:text-subtle outline-none"
          data-blog-search
        />
      </label>

      <!-- Filters -->
      <div class="flex flex-wrap gap-3" aria-label="Blog filters">
        <div
          class="flex items-center gap-2 rounded-xl border border-divider px-3 py-2.5 transition-colors focus-within:border-primary/40"
          style="background: var(--color-card);"
        >
          <Funnel size={13} class="shrink-0 text-subtle" aria-hidden="true" />
          <label for={`${idPrefix}-tag`} class="sr-only">Tag</label>
          <select
            id={`${idPrefix}-tag`}
            value={initialListing.appliedFilters.tag ?? ''}
            class="appearance-none bg-transparent text-sm text-secondary outline-none cursor-pointer"
            data-blog-tag
          >
            <option value="">All tags</option>
            {
              availableTags.map((tag) => (
                <option value={tag.slug}>
                  {tag.name} ({tag.count})
                </option>
              ))
            }
          </select>
        </div>

        <div
          class="flex items-center gap-2 rounded-xl border border-divider px-3 py-2.5 transition-colors focus-within:border-primary/40"
          style="background: var(--color-card);"
        >
          <Funnel size={13} class="shrink-0 text-subtle" aria-hidden="true" />
          <label for={`${idPrefix}-category`} class="sr-only">Category</label>
          <select
            id={`${idPrefix}-category`}
            value={initialListing.appliedFilters.category ?? ''}
            class="appearance-none bg-transparent text-sm text-secondary outline-none cursor-pointer"
            data-blog-category
          >
            <option value="">All categories</option>
            {
              availableCategories.map((category) => (
                <option value={category.slug}>
                  {category.name} ({category.count})
                </option>
              ))
            }
          </select>
        </div>

        <div
          class="flex items-center gap-2 rounded-xl border border-divider px-3 py-2.5 transition-colors focus-within:border-primary/40"
          style="background: var(--color-card);"
        >
          <CalendarDays size={13} class="shrink-0 text-subtle" aria-hidden="true" />
          <label for={`${idPrefix}-sort`} class="sr-only">Sort</label>
          <select
            id={`${idPrefix}-sort`}
            value={initialListing.appliedFilters.sort}
            class="appearance-none bg-transparent text-sm text-secondary outline-none cursor-pointer"
            data-blog-sort
          >
            <option value="newest">Newest</option>
            <option value="oldest">Oldest</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Results -->
    <div data-blog-results>
      {
        initialListing.posts.length === 0 ? (
          <div
            class="rounded-2xl border border-dashed border-divider p-12 text-center"
            style="background: var(--color-card);"
          >
            <p class="m-0 text-secondary">No posts found.</p>
            <p class="m-0 mt-1 text-sm text-subtle">
              Try adjusting the search term or active filters.
            </p>
          </div>
        ) : (
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {initialListing.posts.map((post) => (
              <article
                class="group flex flex-col overflow-hidden rounded-2xl border border-divider transition-all duration-200 hover:border-primary/20 hover:bg-card-hover"
                style="background: var(--color-card);"
              >
                {post.metadata.featuredImage ? (
                  <a
                    href={`/blog/${post.metadata.slug}`}
                    class="block"
                    data-astro-prefetch="hover"
                    tabindex="-1"
                    aria-hidden="true"
                  >
                    <figure
                      class="m-0 flex aspect-video items-center justify-center border-b border-divider p-4"
                      style="background: radial-gradient(circle at top, rgba(96,165,250,0.1), transparent 48%), linear-gradient(180deg, rgba(255,255,255,0.02), rgba(15,22,41,0.96));"
                    >
                      <img
                        src={post.metadata.featuredImage}
                        alt={post.metadata.title}
                        loading="lazy"
                        decoding="async"
                        class="max-h-full w-full object-contain"
                      />
                    </figure>
                  </a>
                ) : null}

                <div class="flex flex-1 flex-col gap-3 p-5">
                  <div class="flex flex-wrap items-center gap-2">
                    <span
                      class="rounded-full border border-primary/20 px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wide text-primary-light"
                      style="background: rgba(59,130,246,0.08);"
                    >
                      {post.metadata.category}
                    </span>
                    <span class="text-xs text-subtle">
                      {new Date(post.metadata.publishedAt).toLocaleDateString('en', {
                        year: 'numeric',
                        month: 'short',
                        day: 'numeric',
                      })}
                    </span>
                    <span class="text-xs text-subtle">·</span>
                    <span class="text-xs text-subtle">{post.metadata.readingTimeText}</span>
                  </div>

                  <h2 class="m-0 text-base font-bold leading-snug text-foreground">
                    <a
                      href={`/blog/${post.metadata.slug}`}
                      class="transition-colors hover:text-primary-light"
                      data-astro-prefetch="hover"
                    >
                      {post.metadata.title}
                    </a>
                  </h2>

                  <p class="m-0 flex-1 text-sm leading-relaxed text-secondary">
                    {post.metadata.description}
                  </p>

                  {post.metadata.tags.length > 0 && (
                    <ul class="m-0 flex flex-wrap gap-1.5 p-0 list-none">
                      {post.metadata.tags.map((tag) => (
                        <li class="rounded-full border border-divider-2 px-2.5 py-0.5 text-xs text-subtle">
                          {tag}
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              </article>
            ))}
          </div>
        )
      }
    </div>

    <!-- Pagination -->
    <div data-blog-pagination>
      {
        initialListing.posts.length > 0 && (
          <div class="mt-10 flex items-center justify-center gap-4">
            <button
              type="button"
              class="rounded-xl border border-divider px-4 py-2 text-sm font-medium text-secondary transition-all duration-150 hover:border-primary/30 hover:text-foreground disabled:cursor-not-allowed disabled:opacity-40"
              style="background: var(--color-card);"
              data-page-target={Math.max(1, initialListing.page - 1)}
              disabled={initialListing.page <= 1}
            >
              Previous
            </button>
            <span class="text-sm text-subtle">
              Page {initialListing.page} of {initialListing.totalPages}
            </span>
            <button
              type="button"
              class="rounded-xl border border-divider px-4 py-2 text-sm font-medium text-secondary transition-all duration-150 hover:border-primary/30 hover:text-foreground disabled:cursor-not-allowed disabled:opacity-40"
              style="background: var(--color-card);"
              data-page-target={Math.min(initialListing.totalPages, initialListing.page + 1)}
              disabled={initialListing.page >= initialListing.totalPages}
            >
              Next
            </button>
          </div>
        )
      }
    </div>
  </div>
</section>

<script>
  import { initializeBlogFilters } from './blog-filters';

  document.querySelectorAll('[data-blog-filters]').forEach((element) => {
    if (element instanceof HTMLElement) {
      initializeBlogFilters(element);
    }
  });
</script>
