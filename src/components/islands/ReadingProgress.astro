<div class="reading-progress" aria-hidden="true" data-reading-progress>
  <div class="reading-progress-bar" style="transform: scaleX(0);" data-reading-progress-bar></div>
</div>

<script>
  import { initializeReadingProgress } from './reading-progress';

  document.querySelectorAll('[data-reading-progress]').forEach((element) => {
    if (element instanceof HTMLElement) {
      initializeReadingProgress(element);
    }
  });
</script>
