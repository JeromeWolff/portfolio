---
import CaseStudy from '@components/CaseStudy.astro';
import SectionHead from '@components/SectionHead.astro';
import { projectsConfig } from '@config/projects';

const { caseStudies, intro } = projectsConfig;
const total = caseStudies.length;
const [featured, ...rest] = caseStudies;
---

<section id="work" class="pt-20 md:pt-28" aria-labelledby="work-heading">
  <SectionHead
    mark="Work"
    note={`${total} case studies`}
    title="Four systems I've lived inside"
    titleId="work-heading"
    intro={intro}
  />

  <!-- Flagship — full-bleed ink plate, the intentional contrast moment -->
  <div class="mt-14 bg-plate py-16 md:mt-20 md:py-24" style="color: var(--color-plate-ink);">
    <div class="mx-auto max-w-6xl px-5 sm:px-8">
      <div class="mb-10 flex items-center gap-4">
        <span class="mono-label text-plate-graphite">Flagship</span>
        <hr class="rule-h flex-1" style="background: var(--color-plate-rule);" />
      </div>
      <CaseStudy study={featured} total={total} plate />
    </div>
  </div>

  <!-- The rest, on paper, alternating rhythm -->
  <div class="mx-auto mt-16 flex max-w-6xl flex-col gap-20 px-5 sm:px-8 md:mt-24 md:gap-32">
    {rest.map((study, i) => <CaseStudy study={study} total={total} reversed={i % 2 === 1} />)}
  </div>
</section>
