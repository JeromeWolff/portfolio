---
import { ArrowRight, ChevronRight } from '@lucide/astro';

import { heroConfig } from '@config/hero';

interface Props {
  title?: string;
  tagline?: string;
  subtext?: string;
  ctaLabel?: string;
  ctaHref?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryHref?: string;
}

const {
  title = heroConfig.title,
  tagline = heroConfig.tagline,
  subtext = heroConfig.subtext,
  ctaLabel = heroConfig.ctaLabel,
  ctaHref = heroConfig.ctaHref,
  ctaSecondaryLabel = heroConfig.ctaSecondaryLabel,
  ctaSecondaryHref = heroConfig.ctaSecondaryHref,
} = Astro.props;

const stats = heroConfig.stats;
---

<section
  id="hero"
  class="relative flex min-h-[92vh] items-center justify-center overflow-hidden"
  aria-labelledby="hero-title"
>
  <!-- Background dot grid -->
  <div class="pointer-events-none absolute inset-0 dot-grid-bg opacity-40" aria-hidden="true"></div>

  <!-- Radial glow -->
  <div class="pointer-events-none absolute inset-0 glow-bg" aria-hidden="true"></div>

  <!-- Ambient orb -->
  <div
    class="pointer-events-none absolute left-1/2 top-1/3 h-[700px] w-[700px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-15 blur-3xl hero-ambient"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-4xl px-4 py-24 text-center sm:px-6">
    <!-- Eyebrow badge -->
    <div
      class="mb-8 inline-flex items-center gap-2 rounded-full border border-divider-2 px-4 py-2 text-sm font-medium text-secondary"
      style="background: rgba(11, 21, 38, 0.6); backdrop-filter: blur(8px);"
    >
      <span
        class="h-1.5 w-1.5 rounded-full bg-success"
        style="animation: pulseSoft 2s ease-in-out infinite;"
        aria-hidden="true"></span>
      {tagline}
    </div>

    <!-- Main heading -->
    <h1
      id="hero-title"
      class="mb-6 text-5xl font-bold leading-none tracking-tight sm:text-6xl md:text-7xl lg:text-8xl"
    >
      <span class="gradient-text">{title}</span>
    </h1>

    <!-- Subtext -->
    <p class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-secondary sm:text-xl">
      {subtext}
    </p>

    <!-- CTAs -->
    <div class="mb-20 flex flex-wrap items-center justify-center gap-4">
      <a
        href={ctaHref}
        class="inline-flex items-center gap-2 rounded-xl px-7 py-3.5 text-base font-semibold text-white transition-all duration-150 hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-canvas"
        style="background: #2563eb; box-shadow: 0 4px 16px rgba(59,130,246,0.35), 0 1px 3px rgba(0,0,0,0.3);"
      >
        {ctaLabel}
        <ArrowRight size={18} aria-hidden="true" />
      </a>
      <a
        href={ctaSecondaryHref}
        class="inline-flex items-center gap-2 rounded-xl border border-divider-2 px-7 py-3.5 text-base font-semibold text-foreground transition-all duration-150 hover:border-primary/40 hover:bg-white/[0.04] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-canvas"
        style="background: rgba(11, 21, 38, 0.6); backdrop-filter: blur(8px);"
      >
        {ctaSecondaryLabel}
        <ChevronRight size={18} aria-hidden="true" />
      </a>
    </div>

    <!-- Stats row -->
    {
      stats && stats.length > 0 && (
        <div class="border-t border-divider pt-10">
          <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
            {stats.map(({ label, value }) => (
              <div class="text-center">
                <div class="gradient-text text-3xl font-bold md:text-4xl">{value}</div>
                <div class="mt-1.5 text-sm text-subtle">{label}</div>
              </div>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>
