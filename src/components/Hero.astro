---
import Diagram from '@components/Diagram.astro';
import { heroConfig } from '@config/hero';

const { cta, eyebrow, lead, spec } = heroConfig;
---

<section id="top" class="relative overflow-hidden">
  <div class="mx-auto max-w-6xl px-5 pt-14 pb-20 sm:px-8 md:pt-20 md:pb-28">
    <!-- Drafting annotation row -->
    <div class="flex items-center justify-between gap-4">
      <span class="mono-label">{eyebrow}</span>
      <span class="mono-label hidden sm:inline">54.42°N / 13.43°E</span>
    </div>
    <hr class="rule-h mt-4" />

    <div class="grid grid-cols-12 gap-x-8 gap-y-14 pt-12 md:pt-16">
      <!-- Thesis -->
      <div class="col-span-12 lg:col-span-8" data-reveal>
        <h1
          class="font-display font-semibold text-ink"
          style="font-size: clamp(2.6rem, 7vw, 5.25rem); line-height: 1.02; letter-spacing: -0.03em;"
        >
          I build the backends that carry{' '}
          <span class="hl-underline whitespace-nowrap">millions</span>{' '}
          of users.
        </h1>

        <p class="mt-8 max-w-xl text-lg leading-relaxed text-graphite">{lead}</p>

        <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-4">
          <a
            href={cta.href}
            class="group inline-flex items-center gap-2.5 border border-ink px-5 py-3 text-sm font-medium text-ink transition-colors duration-200 hover:bg-ink hover:text-paper"
          >
            {cta.label}
            <span
              class="transition-transform duration-200 group-hover:translate-y-0.5"
              aria-hidden="true">↓</span
            >
          </a>
          <p class="mono-label m-0">Currently — CTO at Valorbyte &amp; Shabo Group</p>
        </div>
      </div>

      <!-- Spec block: the data, drafted -->
      <div class="col-span-12 lg:col-span-4 lg:pt-2" data-reveal style="--reveal-delay: 120ms">
        <figure class="m-0">
          <div class="ml-auto max-w-[15rem] text-ink">
            <Diagram kind="network" />
          </div>
          <figcaption class="mono-label mt-2 block text-right">
            fig.00 — distributed systems
          </figcaption>
        </figure>

        <dl class="mt-8 m-0">
          {
            spec.map((row) => (
              <div class="flex items-baseline justify-between gap-4 border-b border-rule py-2.5">
                <dt class="mono-label m-0">{row.key}</dt>
                <dd class="mono-data m-0 text-right text-[0.9rem] font-medium text-ink">
                  {row.value}
                </dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </div>
</section>
