---
import { socialLinks } from '@config/social';

const year = new Date().getFullYear();
---

<footer role="contentinfo" class="mt-8 border-t border-ink bg-paper-sunken">
  <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 md:py-20">
    <nav class="max-w-xs" aria-label="Elsewhere">
      <p class="mono-label">Elsewhere</p>
      <ul class="mt-4 flex flex-col gap-3 list-none m-0 p-0">
        {
          socialLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                target={href.startsWith('http') ? '_blank' : undefined}
                rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
                class="group inline-flex w-full items-center justify-between gap-4 text-graphite transition-colors hover:text-ink"
              >
                <span class="link-draw">{label}</span>
                <span
                  class="text-subtle transition-transform duration-200 group-hover:translate-x-0.5 group-hover:text-ink"
                  aria-hidden="true"
                >
                  ↗
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <!-- Colophon bar -->
  <div class="border-t border-rule">
    <div class="mx-auto max-w-6xl px-5 py-5 sm:px-8">
      <p class="mono-label m-0">© {year} Jerome Wolff</p>
    </div>
  </div>
</footer>
