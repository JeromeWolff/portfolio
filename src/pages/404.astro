---
import Seo from '@components/Seo.astro';
import PageLayout from '@layouts/PageLayout.astro';
---

<PageLayout>
  <Seo
    slot="head"
    title="Page not found | Jerome Wolff"
    description="The requested page could not be found."
    path="/404"
    noindex
  />

  <section class="mx-auto flex min-h-[70vh] max-w-6xl flex-col justify-center px-5 py-24 sm:px-8">
    <div class="flex items-center justify-between gap-4">
      <span class="mono-label">Error</span>
      <span class="mono-label hidden sm:inline">no such coordinate</span>
    </div>
    <hr class="rule-h mt-4" />

    <div class="grid grid-cols-12 gap-x-8 pt-12">
      <p
        class="col-span-12 font-display font-semibold leading-none text-rule-strong md:col-span-4"
        style="font-size: clamp(5rem, 14vw, 10rem);"
        aria-hidden="true"
      >
        404
      </p>
      <div class="col-span-12 md:col-span-7 md:col-start-6 md:self-end">
        <h1 class="text-3xl sm:text-4xl">This page went off the grid.</h1>
        <p class="mt-4 max-w-md text-lg leading-relaxed text-graphite">
          The address doesn't resolve to anything I've built. It may have moved, or it never existed
          in the first place.
        </p>
        <a
          href="/"
          class="group mt-8 inline-flex items-center gap-2.5 border border-ink px-5 py-3 text-sm font-medium text-ink transition-colors duration-200 hover:bg-ink hover:text-paper"
          data-astro-prefetch="hover"
        >
          <span
            class="transition-transform duration-200 group-hover:-translate-x-0.5"
            aria-hidden="true">←</span
          >
          Back to the start
        </a>
      </div>
    </div>
  </section>
</PageLayout>
