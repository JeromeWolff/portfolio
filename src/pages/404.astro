---
import Seo from '@components/Seo.astro';
import PageLayout from '@layouts/PageLayout.astro';
---

<PageLayout>
  <Seo
    slot="head"
    title="Page not found | Jerome Wolff"
    description="The requested page could not be found."
    path="/404"
    noindex
  />

  <section class="relative flex min-h-[70vh] items-center justify-center overflow-hidden">
    <div class="pointer-events-none absolute inset-0 dot-grid-bg opacity-40" aria-hidden="true">
    </div>
    <div class="pointer-events-none absolute inset-0 glow-bg" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-2xl px-4 py-24 text-center sm:px-6">
      <h1 class="mb-6 text-5xl font-bold tracking-tight sm:text-6xl">
        <span class="gradient-text">Page not found</span>
      </h1>
      <p class="mx-auto mb-10 max-w-md text-lg text-secondary">
        The page you were looking for does not exist or is no longer public.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 rounded-xl px-7 py-3.5 text-base font-semibold text-white transition-all duration-150 hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-canvas"
        style="background: #2563eb; box-shadow: 0 4px 16px rgba(59,130,246,0.35), 0 1px 3px rgba(0,0,0,0.3);"
        data-astro-prefetch="hover"
      >
        Back home
      </a>
    </div>
  </section>
</PageLayout>
