---
import Seo from '@components/Seo.astro';
import BlogFilters from '@components/islands/BlogFilters.astro';
import PageLayout from '@layouts/PageLayout.astro';

import { blogService } from '@blog/services/blog.service';

export async function getStaticPaths() {
  const categories = await blogService.getAllCategories();

  return categories.map((category) => ({
    params: { category: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const posts = await blogService.getAllPosts();
const availableTags = await blogService.getAllTags();
const availableCategories = await blogService.getAllCategories();
const serializablePosts = posts.map(({ entry: _entry, ...post }) => post);
const introText = `In “${category.name}”`;
---

<PageLayout>
  <Seo
    slot="head"
    title={`${category.name} Articles | Jerome Wolff`}
    description={`Articles in the ${category.name} category.`}
    path={`/blog/category/${category.slug}`}
  />
  <BlogFilters
    posts={serializablePosts}
    availableTags={availableTags}
    availableCategories={availableCategories}
    initialFilters={{ page: 1, pageSize: 6, sort: 'newest', category: category.slug }}
    introText={introText}
  />
</PageLayout>
