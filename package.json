{
  "browserslist": {
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ],
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ]
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@sentry/react": "^10.51.0",
    "@sentry/vite-plugin": "^5.2.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sass": "^1.99.0",
    "ts-node": "^10.9.2",
    "vite-plugin-svgr": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "ajv": "^8.20.0",
    "autoprefixer": "^10.5.0",
    "cookie": "^1.1.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "jsonc-eslint-parser": "^3.1.0",
    "lint-staged": "^16.4.0",
    "nth-check": "^3.0.1",
    "postcss": "^8.5.13",
    "postcss-import": "^16.1.1",
    "prettier": "^3.8.3",
    "stylelint": "^17.0.0",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-prettier": "^5.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "lint-staged": {
    "*.{cjs,js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md,html}": [
      "prettier --write"
    ]
  },
  "name": "jeromewolff.github.io",
  "overrides": {
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@10.33.2",
  "private": false,
  "scripts": {
    "build": "pnpm run generate:sitemap && tsc && vite build",
    "dev": "vite dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:sitemap": "node generate-sitemap-and-robots.cjs",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "serve": "vite preview",
    "start": "vite",
    "stylelint": "stylelint \"**/*.{css,scss}\"",
    "stylelint:fix": "stylelint \"**/*.{css,scss}\" --fix",
    "test": "vitest",
    "test:coverage": "vitest run --coverage --watch=false",
    "type-check": "tsc --noEmit",
    "validate": "pnpm run lint && pnpm run format:check && pnpm run stylelint && pnpm run type-check"
  },
  "type": "module",
  "version": "1.0.0"
}
