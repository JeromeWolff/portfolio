{
  "browserslist": {
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ],
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ]
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sass": "^1.101.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^10.0.8",
    "@eslint/js": "^10.0.1",
    "@lucide/astro": "^1.17.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.8",
    "astro": "^6.4.6",
    "astro-expressive-code": "^0.43.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsonc": "^3.2.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsonc-eslint-parser": "^3.1.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^17.13.0",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-prettier": "^5.0.3",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{astro,cjs,js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{astro,json,css,scss,md,html}": [
      "prettier --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ]
  },
  "name": "jeromewolff.github.io",
  "packageManager": "pnpm@11.4.0",
  "private": false,
  "scripts": {
    "build": "astro build",
    "dev": "astro dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "preview": "astro preview",
    "serve": "astro preview",
    "start": "astro dev",
    "stylelint": "stylelint \"**/*.{css,scss}\"",
    "stylelint:fix": "stylelint \"**/*.{css,scss}\" --fix",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:coverage": "vitest run --coverage --watch=false",
    "test:e2e": "playwright test",
    "test:unit": "vitest run",
    "type-check": "astro check",
    "validate": "pnpm run lint && pnpm run stylelint && pnpm run format:check && pnpm run type-check"
  },
  "type": "module",
  "version": "1.0.0"
}
